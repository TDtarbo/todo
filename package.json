{
    "name": "todo",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "dist-electron/main/main.js",
    "scripts": {
        "dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:5173 dist-electron/main/main.js && electron .\"",
        "build": "vite build && tsc -p tsconfig.electron.json",
        "dist:win": "npm run build && electron-builder --win nsis",
        "dist:win-portable": "npm run build && electron-builder --win portable"
    },
    "build": {
        "appId": "com.finito.todo",
        "productName": "FINITO",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**",
            "dist-electron/**",
            "package.json"
        ],
        "win": {
            "target": [
                "nsis",
                "portable"
            ]
        }
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.4",
        "better-sqlite3": "^12.10.0",
        "dayjs": "^1.11.20",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-icons": "^5.6.0",
        "react-router-dom": "^7.15.0",
        "tailwindcss": "^4.2.4"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/electron": "^1.4.38",
        "@types/node": "^24.12.4",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "drizzle-kit": "^0.18.1",
        "electron": "^42.1.0",
        "electron-builder": "^26.0.12",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "ts-node": "^10.9.2",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.10",
        "wait-on": "^9.0.10"
    }
}
